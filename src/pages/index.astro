---
import Layout from '../layouts/Layout.astro';
import samples from '../data/samples.json';
---

<Layout title="Zain Haq — Technical Writer">
  <!-- Nav -->
  <nav class="nav">
    <a href="#top" class="nav-logo">ZH</a>
    <div class="nav-links">
      <a href="#writing" class="nav-link">Writing</a>
      <a href="#about" class="nav-link">About</a>
      <a href="#contact" class="nav-link">Contact</a>
    </div>
  </nav>

  <!-- Hero -->
  <header id="top" class="hero">
    <div class="hero-inner">
      <h1 class="hero-title">Zain Haq</h1>
      <p class="hero-subtitle">Technical Writer</p>
      <p class="hero-sub">
        I write API docs and developer guides, and build AI
        tools that keep them accurate. Working on Amazon
        Supply Chain Services.
      </p>
      <div class="hero-divider"></div>
    </div>
  </header>

  <!-- Writing samples -->
  <section id="writing" class="section">
    <div class="section-inner">
      <p class="section-label">Selected work</p>
      <h2 class="section-title">Writing samples</h2>
      <div class="samples-grid">
        {samples.map((sample) => (
          <a href={`/samples/${sample.file}`} target="_blank" rel="noopener noreferrer" class="card">
            <div class="card-top">
              <span class="card-type">{sample.type}</span>
              <span class="card-audience">{sample.audience}</span>
            </div>
            <h3 class="card-title">{sample.title}</h3>
            <p class="card-desc">{sample.description}</p>
            <div class="card-footer">
              <span class="view-link">
                View PDF <span class="arrow">&#8599;</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section-alt">
    <div class="section-inner">
      <p class="section-label">Background</p>
      <h2 class="section-title">About</h2>
      <div class="about-content">
        <div>
          <p class="about-paragraph">
            I'm a technical writer with over seven years of experience
            documenting APIs, developer tools, and cloud infrastructure. I
            currently work at Amazon, where I write documentation for
            Amazon Supply Chain Services and build tools to improve
            content quality across the team's docs. Most recently, I built
            a VS Code extension that scores documentation drafts on
            technical, editorial, and stylistic accuracy and checks them
            against existing internal and public-facing content. Writers
            catch inconsistencies before review instead of after.
          </p>
          <p class="about-paragraph">
            Before Amazon, I spent five years at H2O.ai documenting
            machine learning platforms. I led the team's documentation
            platform migration to Docusaurus and integrated docs pipelines
            with CI/CD tooling, work that shaped how I operate now: docs
            as code, reviewed and shipped with the same rigor as the
            product.
          </p>
          <p class="about-paragraph">
            Teams I work with get a writer who tests the product hands-on
            and reads the source when the spec is ambiguous. I give
            engineers and product managers documentation feedback they can
            act on. Clear, accurate content structured around real use
            cases is the goal, and I take ownership of getting it there.
          </p>
        </div>
        <div class="about-sidebar">
          <div class="about-block">
            <p class="about-block-label">Currently</p>
            <p class="about-block-value">Technical Writer, Amazon</p>
          </div>
          <div class="about-block">
            <p class="about-block-label">Education</p>
            <p class="about-block-value">B.A. English Studies, Northern Illinois University</p>
          </div>
          <div class="about-block">
            <p class="about-block-label">Location</p>
            <p class="about-block-value">Seattle, WA</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section">
    <div class="section-inner">
      <p class="section-label">Get in touch</p>
      <h2 class="section-title">Contact</h2>
      <div class="contact-grid">
        <a href="mailto:zain.m.haq@gmail.com" class="contact-card">
          <span class="contact-label">Email</span>
          <span class="contact-value">zain.m.haq@gmail.com</span>
        </a>
        <a href="https://linkedin.com/in/zain-haq" class="contact-card">
          <span class="contact-label">LinkedIn</span>
          <span class="contact-value">linkedin.com/in/zain-haq</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <p>&copy; 2026 Zain Haq</p>
  </footer>
</Layout>
