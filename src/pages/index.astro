---
import Layout from '../layouts/Layout.astro';
import samples from '../data/samples.json';
---

<Layout title="Zain Haq — Technical Writer">
  <!-- Nav -->
  <nav class="nav">
    <a href="#top" class="nav-logo">ZH</a>
    <div class="nav-links">
      <a href="#writing" class="nav-link">Writing</a>
      <a href="#about" class="nav-link">About</a>
      <a href="#contact" class="nav-link">Contact</a>
    </div>
  </nav>

  <!-- Hero -->
  <header id="top" class="hero">
    <div class="hero-inner">
      <p class="hero-name">Zain Haq</p>
      <h1 class="hero-title">Technical Writer</h1>
      <p class="hero-sub">
        I write API documentation, developer guides, and integration content
        for technical audiences. Currently at Amazon, working on Supply Chain
        Services and developer tooling.
      </p>
      <div class="hero-divider"></div>
    </div>
  </header>

  <!-- Writing samples -->
  <section id="writing" class="section">
    <div class="section-inner">
      <p class="section-label">Selected work</p>
      <h2 class="section-title">Writing samples</h2>
      <div class="samples-grid">
        {samples.map((sample) => (
          <a href={`/samples/${sample.file}`} target="_blank" rel="noopener noreferrer" class="card">
            <div class="card-top">
              <span class="card-type">{sample.type}</span>
              <span class="card-audience">{sample.audience}</span>
            </div>
            <h3 class="card-title">{sample.title}</h3>
            <p class="card-desc">{sample.description}</p>
            <div class="card-footer">
              <span class="view-link">
                View PDF <span class="arrow">&#8599;</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section-alt">
    <div class="section-inner">
      <p class="section-label">Background</p>
      <h2 class="section-title">About</h2>
      <div class="about-content">
        <div>
          <p class="about-paragraph">
            I'm a technical writer with over seven years of experience
            documenting APIs, developer tools, and cloud infrastructure. I
            currently work at Amazon, where I create documentation for
            Amazon Supply Chain Services and build AI-powered tooling to
            improve content quality.
          </p>
          <p class="about-paragraph">
            Before Amazon, I spent five years at H2O.ai, where I documented
            machine learning platforms, led a documentation platform
            migration to Docusaurus, and integrated docs pipelines with
            CI/CD tooling.
          </p>
          <p class="about-paragraph">
            I care about documentation that is clear, accurate, and
            structured around real use cases. I work in a docs-as-code
            workflow and believe good documentation should be as rigorously
            maintained as the product it describes.
          </p>
        </div>
        <div class="about-sidebar">
          <div>
            <p class="about-block-label">Currently</p>
            <p class="about-block-value">Technical Writer, Amazon</p>
          </div>
          <div>
            <p class="about-block-label">Previously</p>
            <p class="about-block-value">Senior Technical Writer, H2O.ai</p>
          </div>
          <div>
            <p class="about-block-label">Education</p>
            <p class="about-block-value">B.A. English Studies, Northern Illinois University</p>
          </div>
          <div>
            <p class="about-block-label">Location</p>
            <p class="about-block-value">Seattle, WA</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section">
    <div class="section-inner">
      <p class="section-label">Get in touch</p>
      <h2 class="section-title">Contact</h2>
      <div class="contact-grid">
        <a href="mailto:zain.m.haq@gmail.com" class="contact-card">
          <p class="contact-label">Email</p>
          <p class="contact-value">zain.m.haq@gmail.com</p>
        </a>
        <a href="https://linkedin.com/in/zain-haq" target="_blank" rel="noopener noreferrer" class="contact-card">
          <p class="contact-label">LinkedIn</p>
          <p class="contact-value">linkedin.com/in/zain-haq</p>
        </a>
        <a href="https://zainmhaq.com" class="contact-card">
          <p class="contact-label">Website</p>
          <p class="contact-value">zainmhaq.com</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <p class="footer-text">&copy; 2026 Zain Haq</p>
  </footer>
</Layout>
